rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, 'subscriber' or 'admin')
    //   - subscriptionStatus: string ('active', 'inactive', 'lapsed')
    //   - subscriptionPlan: string ('monthly', 'yearly')
    //   - renewalDate: timestamp
    //   - charityId: string
    //   - charityPercentage: number (min 10)
    //   - totalWinnings: number
    //
    // Collection: users/{userId}/scores
    // Document ID: {scoreId}
    // Fields:
    //   - uid: string (required)
    //   - score: number (required, 1-45)
    //   - date: timestamp (required)
    //
    // Collection: charities
    // Document ID: {charityId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - description: string
    //   - image: string
    //   - totalDonations: number
    //   - featured: bool
    //
    // Collection: draws
    // Document ID: {drawId}
    // Fields:
    //   - id: string (required)
    //   - date: timestamp (required)
    //   - winningNumbers: list (5 numbers)
    //   - prizePoolTotal: number
    //   - status: string ('simulated', 'published')
    //   - jackpotRollover: number
    //
    // Collection: winners
    // Document ID: {winnerId}
    // Fields:
    //   - id: string (required)
    //   - drawId: string (required)
    //   - uid: string (required)
    //   - matchType: number (3, 4, 5)
    //   - prizeAmount: number
    //   - proofUrl: string
    //   - status: string ('pending', 'paid', 'rejected')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aseth6779@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['subscriber', 'admin'] &&
             (data.charityPercentage == null || (data.charityPercentage is number && data.charityPercentage >= 10));
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'score', 'date']) &&
             data.uid == request.auth.uid &&
             data.score is number && data.score >= 1 && data.score <= 45 &&
             data.date is timestamp;
    }

    function isValidCharity(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string &&
             data.name is string &&
             data.name.size() < 100;
    }

    function isValidDraw(data) {
      return data.keys().hasAll(['id', 'date', 'status']) &&
             data.status in ['simulated', 'published'] &&
             data.date is timestamp;
    }

    function isValidWinner(data) {
      return data.keys().hasAll(['id', 'drawId', 'uid', 'matchType', 'status']) &&
             data.matchType in [3, 4, 5] &&
             data.status in ['pending', 'paid', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'subscriber';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();

      match /scores/{scoreId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidScore(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /charities/{charityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidCharity(request.resource.data);
    }

    match /draws/{drawId} {
      allow read: if isAuthenticated() && (resource.data.status == 'published' || isAdmin());
      allow write: if isAdmin() && isValidDraw(request.resource.data);
    }

    match /winners/{winnerId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWinner(request.resource.data); // Logic for winning would be server-side or admin-verified
      allow update: if isAdmin() && isValidWinner(request.resource.data);
    }
  }
}
